{
  "name": "react-crash-guard",
  "version": "1.1.0",
  "description": "Production-grade React error boundary patterns for SaaS applications",
  "author": "Muhammad Zia <mughalheree@gmail.com>",
  "license": "MIT",
  "homepage": "https://mughalhere.github.io/react-crash-guard/",
  "repository": {
    "type": "git",
    "url": "https://github.com/mughalhere/react-crash-guard"
  },
  "bugs": {
    "url": "https://github.com/mughalhere/react-crash-guard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "error-boundary",
    "error-handling",
    "sentry",
    "cloudwatch",
    "aws",
    "typescript",
    "saas"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@sentry/react": ">=7.0.0",
    "@aws-sdk/client-cloudwatch-logs": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@sentry/react": {
      "optional": true
    },
    "@aws-sdk/client-cloudwatch-logs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
